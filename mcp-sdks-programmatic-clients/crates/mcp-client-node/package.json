{
    "name": "@modelcontextprotocol/client-augmentation-native",
    "version": "0.0.1",
    "description": "NAPI-RS native addon backing @modelcontextprotocol/client-augmentation",
    "main": "index.js",
    "types": "index.d.ts",
    "napi": {
        "binaryName": "mcp-client-node",
        "targets": [
            "aarch64-apple-darwin",
            "x86_64-apple-darwin",
            "x86_64-unknown-linux-gnu",
            "aarch64-unknown-linux-gnu",
            "x86_64-pc-windows-msvc"
        ]
    },
    "scripts": {
        "build": "napi build --platform --release",
        "build:debug": "napi build --platform"
    },
    "devDependencies": {
        "@napi-rs/cli": "^3.0.0"
    },
    "license": "MIT",
    "files": [
        "index.js",
        "index.d.ts",
        "*.node"
    ]
}
