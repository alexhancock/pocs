{
  "name": "mcp-with-attribution",
  "version": "1.0.0",
  "description": "PoC demonstrating MCP client/server with attribution and payment capabilities",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:web": "node dist/web-server.js",
    "start:mcp": "node dist/mcp-server.js",
    "start:frontend": "node dist/frontend-server.js",
    "start:all": "concurrently -k -n web,mcp,fe -c blue,green,magenta 'npm:start:web' 'npm:start:mcp' 'npm:start:frontend'",
    "dev:web": "tsx src/web-server.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "dev:frontend": "tsx src/frontend-server.ts",
    "dev:all": "concurrently -k -n web,mcp,fe -c blue,green,magenta 'npm:dev:web' 'npm:dev:mcp' 'npm:dev:frontend'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
